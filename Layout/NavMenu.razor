<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Cửa hàng demo</a>
        <button title="Menu điều hướng" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-cart-check-fill-nav-menu" aria-hidden="true"></span> Cửa hàng
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="gio-hang">
                <span class="bi bi-bag-fill-nav-menu" aria-hidden="true"></span> Kiểm tra giỏ hàng
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="thanh-toan">
                <span class="bi bi-credit-card-fill-nav-menu" aria-hidden="true"></span> Thanh toán
            </NavLink>
        </div>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}
